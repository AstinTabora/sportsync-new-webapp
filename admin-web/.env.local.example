# Firebase Web SDK config — get these from Firebase Console
# → Project Settings → Your apps → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=sportsync-376d7.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=sportsync-376d7
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=sportsync-376d7.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=412008010823
NEXT_PUBLIC_FIREBASE_APP_ID=

# Server-side: Firebase Admin SDK service account JSON (single line, escaped)
# Or set GOOGLE_APPLICATION_CREDENTIALS to a file path on the host.
FIREBASE_ADMIN_CREDENTIALS=

# Google Maps JS API key — for the location picker on the court form
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
